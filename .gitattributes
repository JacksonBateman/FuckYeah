# Normalise text files to LF in the repository
* text=auto eol=lf

# Unity text-based files
*.cs text eol=lf
*.shader text eol=lf
*.compute text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.meta text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.overrideController text eol=lf
*.playable text eol=lf
*.physicMaterial text eol=lf
*.physicsMaterial2D text eol=lf

# Windows scripts require CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Shell scripts require LF
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.tif binary
*.tiff binary
*.psd binary
*.fbx binary
*.blend binary
*.wav binary
*.mp3 binary
*.ogg binary
*.mp4 binary
*.mov binary
*.dll binary
*.so binary
*.dylib binary
*.exe binary
*.zip binary
*.unitypackage binary